# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Required for admin profile updates (bypasses RLS). Get from Supabase Dashboard → Settings → API. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin (optional; default is admin123)
ADMIN_PASSWORD=your_admin_password
# For “Forgot password” email (reset link sent to this address)
ADMIN_EMAIL=maidaamjad32@gmail.com
# Resend.com API key for sending reset emails (get from https://resend.com)
RESEND_API_KEY=re_your_key
# Optional: base URL for reset links (e.g. https://yoursite.com). Defaults to request origin.
# NEXT_PUBLIC_APP_URL=https://yoursite.com
